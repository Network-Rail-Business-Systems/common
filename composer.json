{
    "name": "networkrailbusinesssystems/common",
    "description": "Provides common functionality for Network Rail Business Systems Laravel systems",
    "type": "library",
    "homepage": "https://github.com/Network-Rail-Business-Systems/common",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "NetworkRailBusinessSystems\\Common\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NetworkRailBusinessSystems\\Common\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Tahreem Asghar",
            "email": "Tahreem.Asghar@networkrail.co.uk"
        },
        {
            "name": "Michael Dono",
            "email": "Michael.Dono2@networkrail.co.uk"
        }
    ],
    "minimum-stability": "dev",
    "require" : {
        "php": "^8.3",
        "anthonyedmonds/laravel-find": "dev-laravel-13",
        "anthonyedmonds/laravel-form-builder": "dev-laravel-13",
        "illuminate/support": "^13",
        "lab404/laravel-impersonate": "^1",
        "laracasts/flash": "^3",
        "networkrailbusinesssystems/activity-log": "dev-laravel-13",
        "networkrailbusinesssystems/entra": "dev-laravel-13",
        "spatie/laravel-permission": "^6",
        "spatie/simple-excel": "^3"
    },
    "require-dev" : {
        "anthonyedmonds/laravel-testing-traits": "dev-laravel-13",
        "brianium/paratest": "^7",
        "larastan/larastan": "^3",
        "laravel/pint": "^1",
        "networkrailbusinesssystems/badges": "dev-laravel-13",
        "orchestra/testbench": "^11",
        "phpunit/phpunit": "^12"
    },
    "config" : {
        "sort-packages" : true
    },
    "extra" : {
        "laravel" : {
            "providers" : [
                "NetworkRailBusinessSystems\\Common\\CommonServiceProvider"
            ]
        }
    }
}
